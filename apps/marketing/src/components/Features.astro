---
import Container from './Container.astro';

interface FeatureCard {
  icon: string;
  title: string;
  body: string;
}
interface Props {
  eyebrow: string;
  heading: string;
  cards: readonly FeatureCard[];
}
const { eyebrow, heading, cards } = Astro.props;
---

<section id="features" class="py-24 md:py-36">
  <Container>
    <div class="max-w-[720px] mb-16 md:mb-20">
      <p class="font-mono text-xs uppercase tracking-[0.08em] text-klano-text-3 mb-4">{eyebrow}</p>
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.05] tracking-[-0.02em] text-klano-text">
        {heading}
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3 md:gap-5">
      {
        cards.map((card) => (
          <article class="feat-card">
            <div class="feat-icon" aria-hidden="true" set:html={card.icon} />
            <h3 class="feat-title">{card.title}</h3>
            <p class="feat-body">{card.body}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .feat-card {
    background: var(--color-klano-surface);
    border: 1px solid var(--color-klano-border);
    border-radius: 20px;
    padding: 28px;
    transition: border-color 200ms, transform 200ms;
  }
  @media (min-width: 768px) {
    .feat-card { padding: 32px; }
  }
  .feat-card:hover {
    border-color: var(--color-klano-border-strong);
    transform: translateY(-2px);
  }
  .feat-icon {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--color-klano-border);
    border-radius: 10px;
    color: var(--color-klano-text);
    margin-bottom: 20px;
  }
  .feat-icon :global(svg) {
    width: 18px; height: 18px;
    stroke-width: 1.5;
  }
  .feat-title {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-klano-text);
    margin-bottom: 8px;
  }
  .feat-body {
    color: var(--color-klano-text-2);
    font-size: 14px;
    line-height: 1.6;
  }
</style>
