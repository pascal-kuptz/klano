---
interface Props {
  locale: 'de' | 'en';
}
const { locale } = Astro.props;

const t = locale === 'de'
  ? {
      title: 'Probe finden',
      sub: 'KW 18 · 5 Mitglieder',
      members: ['Léa', 'David', 'Marc', 'Tina'],
      days: ['Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa', 'So'],
      proposal: 'Klano schlägt vor: Donnerstag, 19:30',
    }
  : {
      title: 'Find rehearsal',
      sub: 'Week 18 · 5 members',
      members: ['Léa', 'David', 'Marc', 'Tina'],
      days: ['Mo', 'Tu', 'We', 'Th', 'Fr', 'Sa', 'Su'],
      proposal: 'Klano suggests: Thursday, 19:30',
    };

// Status grid: 4 members × 7 days. f = free, b = busy, t = tentative.
const grid: ('f' | 'b' | 't')[][] = [
  ['b', 'b', 't', 'f', 'f', 'b', 'f'],
  ['f', 'b', 't', 'f', 'b', 'b', 't'],
  ['t', 'f', 'f', 'f', 'f', 'b', 'f'],
  ['b', 't', 'f', 'f', 'b', 'f', 'f'],
];
const proposalCol = 3; // Donnerstag
---

<div class="mock sync-mock">
  <div class="mock-chrome">
    <span class="mock-dot mock-dot-r"></span>
    <span class="mock-dot mock-dot-y"></span>
    <span class="mock-dot mock-dot-g"></span>
    <span class="mock-url">app.klano.ai/sync</span>
  </div>
  <div class="mock-body">
    <div class="mock-header">
      <div>
        <h4 class="mock-title">{t.title}</h4>
        <p class="mock-sub">{t.sub}</p>
      </div>
    </div>

    <div class="cal">
      <div class="cal-row cal-row-head">
        <span class="cal-cell cal-cell-name"></span>
        {t.days.map((d, i) => (
          <span class:list={['cal-cell cal-cell-day', i === proposalCol && 'is-proposal']}>{d}</span>
        ))}
      </div>
      {
        t.members.map((name, mi) => (
          <div class="cal-row">
            <span class="cal-cell cal-cell-name">{name}</span>
            {grid[mi]!.map((status, di) => (
              <span
                class:list={[
                  'cal-cell cal-status',
                  status === 'f' && 'is-free',
                  status === 'b' && 'is-busy',
                  status === 't' && 'is-tentative',
                  di === proposalCol && 'in-proposal',
                ]}
              />
            ))}
          </div>
        ))
      }
    </div>

    <div class="mock-ai-bar">
      <span class="mock-ai-dot"></span>
      <span class="mock-ai-text">{t.proposal}</span>
    </div>
  </div>
</div>

<style>
  .mock {
    background: var(--color-klano-stage);
    border: 1px solid var(--color-klano-edge);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }
  .mock-chrome {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px;
    background: var(--color-klano-void);
    border-bottom: 1px solid var(--color-klano-edge-soft);
  }
  .mock-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--color-klano-mist); }
  .mock-dot-r { background: #FF5C39; }
  .mock-dot-y { background: #F4B942; }
  .mock-dot-g { background: #5DD4A0; }
  .mock-url {
    margin-left: 12px;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    color: var(--color-klano-fog);
  }
  .mock-body { padding: 20px; }
  @media (min-width: 768px) { .mock-body { padding: 28px; } }
  .mock-header { margin-bottom: 20px; }
  .mock-title {
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--color-klano-pearl);
    letter-spacing: -0.015em;
  }
  .mock-sub {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    margin-top: 4px;
  }

  .cal {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cal-row {
    display: grid;
    grid-template-columns: 56px repeat(7, 1fr);
    gap: 4px;
    align-items: center;
  }
  .cal-row-head .cal-cell-day {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    text-align: center;
    padding: 6px 0;
  }
  .cal-cell-day.is-proposal {
    color: var(--color-klano-acid);
    background: rgba(197, 242, 92, 0.06);
    border-radius: 6px;
  }
  .cal-cell-name {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    color: var(--color-klano-bone);
    padding: 6px 0;
  }
  .cal-status {
    height: 26px;
    border-radius: 6px;
    border: 1px solid var(--color-klano-edge);
  }
  .cal-status.is-free { background: rgba(93, 212, 160, 0.12); border-color: rgba(93, 212, 160, 0.3); }
  .cal-status.is-busy { background: var(--color-klano-card); border-color: var(--color-klano-edge); }
  .cal-status.is-busy::after {
    content: '';
    display: block;
    width: 100%; height: 100%;
    background: repeating-linear-gradient(45deg, transparent 0 3px, rgba(255,255,255,0.05) 3px 4px);
    border-radius: inherit;
  }
  .cal-status.is-tentative { background: rgba(244, 185, 66, 0.12); border-color: rgba(244, 185, 66, 0.3); }
  .cal-status.in-proposal {
    box-shadow: 0 0 0 1px rgba(197, 242, 92, 0.4);
  }

  .mock-ai-bar {
    margin-top: 20px;
    padding: 12px 14px;
    background: linear-gradient(90deg, rgba(197, 242, 92, 0.06) 0%, transparent 100%);
    border: 1px solid rgba(197, 242, 92, 0.2);
    border-radius: 10px;
    display: flex; align-items: center; gap: 12px;
  }
  .mock-ai-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-klano-acid);
    box-shadow: 0 0 8px var(--color-klano-acid);
    flex-shrink: 0;
  }
  .mock-ai-text {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-size: 13px;
    color: var(--color-klano-bone);
  }
</style>
