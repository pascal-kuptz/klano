---
/**
 * Faux Klano Bookings dashboard — kanban view. Shows the band's current
 * outreach pipeline with status columns, venue cards, and Klano-AI annotations.
 * Pure CSS/SVG, no real data.
 */
interface Props {
  locale: 'de' | 'en';
}
const { locale } = Astro.props;

const t = locale === 'de'
  ? {
      title: 'Bookings · Halbnacht',
      sub: 'Frühling 2026 · 6 aktiv',
      cols: ['Drafted · 1', 'Sent · 2', 'Opened · 1', 'Replied · 1', 'Booked · 0'],
      cards: [
        { col: 0, name: 'Kammgarn', city: 'Schaffhausen', match: '76%', meta: 'Draft · Klano schreibt' },
        { col: 1, name: 'Mascotte', city: 'Zürich', match: '89%', meta: 'Sent · vor 2 Tagen' },
        { col: 1, name: 'Sender', city: 'Winterthur', match: '87%', meta: 'Sent · vor 7 Tagen' },
        { col: 2, name: 'Bogen F', city: 'Zürich', match: '94%', meta: 'Opened · gestern · 18:42' },
        { col: 3, name: 'Helsinki', city: 'Zürich', match: '81%', meta: 'Reply · 17. Mai · 800 CHF', hot: true },
      ],
      ai: 'Klano: Antwort von Helsinki ist positiv. Bestätigen?',
    }
  : {
      title: 'Bookings · Halbnacht',
      sub: 'Spring 2026 · 6 active',
      cols: ['Drafted · 1', 'Sent · 2', 'Opened · 1', 'Replied · 1', 'Booked · 0'],
      cards: [
        { col: 0, name: 'Kammgarn', city: 'Schaffhausen', match: '76%', meta: 'Draft · Klano writing' },
        { col: 1, name: 'Mascotte', city: 'Zürich', match: '89%', meta: 'Sent · 2 days ago' },
        { col: 1, name: 'Sender', city: 'Winterthur', match: '87%', meta: 'Sent · 7 days ago' },
        { col: 2, name: 'Bogen F', city: 'Zürich', match: '94%', meta: 'Opened · yesterday · 18:42' },
        { col: 3, name: 'Helsinki', city: 'Zürich', match: '81%', meta: 'Reply · May 17 · 800 CHF', hot: true },
      ],
      ai: 'Klano: reply from Helsinki is positive. Confirm?',
    };
---

<div class="mock booking-mock">
  <div class="mock-chrome">
    <span class="mock-dot mock-dot-r"></span>
    <span class="mock-dot mock-dot-y"></span>
    <span class="mock-dot mock-dot-g"></span>
    <span class="mock-url">app.klano.ai/bookings</span>
  </div>
  <div class="mock-body">
    <div class="mock-header">
      <div>
        <h4 class="mock-title">{t.title}</h4>
        <p class="mock-sub">{t.sub}</p>
      </div>
      <span class="mock-pill">
        <span class="dot"></span>
        AI live
      </span>
    </div>

    <div class="mock-board">
      {
        t.cols.map((col, i) => (
          <div class="mock-col">
            <div class="mock-col-head">{col}</div>
            <div class="mock-col-body">
              {t.cards
                .filter((c) => c.col === i)
                .map((c) => (
                  <div class:list={['mock-card', c.hot && 'is-hot']}>
                    <div class="mock-card-top">
                      <span class="mock-card-name">{c.name}</span>
                      <span class="mock-card-match">{c.match}</span>
                    </div>
                    <div class="mock-card-city">{c.city}</div>
                    <div class="mock-card-meta">{c.meta}</div>
                  </div>
                ))}
            </div>
          </div>
        ))
      }
    </div>

    <div class="mock-ai-bar">
      <span class="mock-ai-dot"></span>
      <span class="mock-ai-text">{t.ai}</span>
    </div>
  </div>
</div>

<style>
  .mock {
    background: var(--color-klano-stage);
    border: 1px solid var(--color-klano-edge);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
    position: relative;
  }
  .mock-chrome {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--color-klano-void);
    border-bottom: 1px solid var(--color-klano-edge-soft);
  }
  .mock-dot {
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--color-klano-mist);
  }
  .mock-dot-r { background: #FF5C39; }
  .mock-dot-y { background: #F4B942; }
  .mock-dot-g { background: #5DD4A0; }
  .mock-url {
    margin-left: 12px;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    color: var(--color-klano-fog);
  }
  .mock-body {
    padding: 20px;
  }
  @media (min-width: 768px) {
    .mock-body { padding: 28px; }
  }
  .mock-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }
  .mock-title {
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: 16px;
    color: var(--color-klano-pearl);
    letter-spacing: -0.015em;
  }
  .mock-sub {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    margin-top: 4px;
  }
  .mock-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(197, 242, 92, 0.1);
    border: 1px solid rgba(197, 242, 92, 0.3);
    color: var(--color-klano-acid);
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .mock-pill .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-klano-acid);
    box-shadow: 0 0 6px var(--color-klano-acid);
    animation: mock-blip 2s ease-in-out infinite;
  }
  @keyframes mock-blip {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  .mock-board {
    display: grid;
    grid-template-columns: repeat(5, minmax(120px, 1fr));
    gap: 12px;
    overflow-x: auto;
    margin: 0 -8px;
    padding: 0 8px 8px;
  }
  .mock-col {
    min-width: 120px;
  }
  .mock-col-head {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-klano-edge-soft);
  }
  .mock-col-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mock-card {
    background: var(--color-klano-card);
    border: 1px solid var(--color-klano-edge);
    border-radius: 8px;
    padding: 10px 12px;
    transition: border-color 200ms;
  }
  .mock-card.is-hot {
    border-color: rgba(197, 242, 92, 0.4);
    background: linear-gradient(180deg, rgba(197, 242, 92, 0.08) 0%, var(--color-klano-card) 100%);
  }
  .mock-card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }
  .mock-card-name {
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-weight: 600;
    font-size: 12px;
    color: var(--color-klano-pearl);
  }
  .mock-card-match {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    color: var(--color-klano-acid);
  }
  .mock-card-city {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    color: var(--color-klano-sand);
    margin-top: 2px;
  }
  .mock-card-meta {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 10px;
    color: var(--color-klano-fog);
    margin-top: 6px;
    letter-spacing: 0.04em;
  }

  .mock-ai-bar {
    margin-top: 20px;
    padding: 12px 14px;
    background: linear-gradient(90deg, rgba(197, 242, 92, 0.06) 0%, transparent 100%);
    border: 1px solid rgba(197, 242, 92, 0.2);
    border-radius: 10px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .mock-ai-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-klano-acid);
    box-shadow: 0 0 8px var(--color-klano-acid);
    flex-shrink: 0;
  }
  .mock-ai-text {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-size: 13px;
    color: var(--color-klano-bone);
  }
</style>
