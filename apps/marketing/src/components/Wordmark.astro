---
import TrackMarker from './TrackMarker.astro';

interface Props {
  track: string;
  labelTop: string;
  labelSub: string;
  caption: string;
}
const { track, labelTop, labelSub, caption } = Astro.props;
---

<section
  id="how"
  class="wordmark-section py-24 lg:py-36 overflow-hidden relative border-y border-klano-edge-soft"
>
  <div class="max-w-screen-xl mx-auto px-4 md:px-8 xl:px-12">
    <div class="flex flex-col gap-2 mb-10 md:mb-14">
      <TrackMarker num={track} label="Track" />
      <span class="font-mono text-[11px] tracking-[0.18em] uppercase text-klano-bone mt-2">
        {labelTop} <span class="text-klano-fog">·</span> <em class="italic-coral">{labelSub}</em>
      </span>
    </div>

    <div class="massive-mark relative w-full leading-[0.78]">
      <span class="text">kla<span class="o">n</span>o</span>
      <svg
        class="waveform-decoration"
        preserveAspectRatio="none"
        viewBox="0 0 1000 100"
        fill="none"
        aria-hidden="true"
      >
        <line x1="0" y1="50" x2="1000" y2="50" stroke="#46414B" stroke-width="0.5" opacity="0.4"></line>
        <g stroke="#C5F25C" stroke-width="1.5" stroke-linecap="round" opacity="0.55">
          <line x1="50" y1="36" x2="50" y2="64"></line>
          <line x1="125" y1="22" x2="125" y2="78"></line>
          <line x1="200" y1="38" x2="200" y2="62"></line>
          <line x1="290" y1="30" x2="290" y2="70"></line>
          <line x1="365" y1="14" x2="365" y2="86" stroke="#FF5C39"></line>
          <line x1="425" y1="26" x2="425" y2="74"></line>
          <line x1="500" y1="18" x2="500" y2="82" stroke="#FF5C39"></line>
          <line x1="575" y1="30" x2="575" y2="70"></line>
          <line x1="635" y1="24" x2="635" y2="76"></line>
          <line x1="710" y1="28" x2="710" y2="72"></line>
          <line x1="780" y1="36" x2="780" y2="64"></line>
          <line x1="845" y1="40" x2="845" y2="60"></line>
          <line x1="920" y1="44" x2="920" y2="56"></line>
        </g>
      </svg>
    </div>

    <div class="mt-10 md:mt-14 grid gap-6 md:grid-cols-[5fr_3fr] md:gap-12 md:items-end">
      <p class="wordmark-caption max-w-xl">
        {caption}
      </p>
      <div class="font-mono text-[11px] tracking-[0.18em] uppercase text-klano-fog md:text-right">
        01:47 / 03:21 · BPM 124 · GMaj
      </div>
    </div>
  </div>
</section>

<style>
  .italic-coral {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-weight: 400;
    color: var(--color-klano-coral);
    text-transform: none;
    letter-spacing: 0;
    font-size: 13px;
  }
  .massive-mark .text {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 900;
    font-size: clamp(6rem, 28vw, 19rem);
    color: var(--color-klano-pearl);
    letter-spacing: -0.075em;
    display: block;
    position: relative;
    z-index: 2;
  }
  .massive-mark .text .o {
    color: var(--color-klano-coral);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
  }
  .waveform-decoration {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 55%;
    transform: translateY(-50%);
    z-index: 1;
    pointer-events: none;
  }
  .wordmark-caption {
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-klano-bone);
  }
</style>
