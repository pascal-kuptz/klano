---
interface Props {
  labelTop: string;
  labelSub: string;
  caption: string;
}
const { labelTop, labelSub, caption } = Astro.props;
---

<section
  id="how"
  class="wordmark-section py-20 lg:py-32 border-b border-klano-edge overflow-hidden relative"
>
  <div class="max-w-screen-xl mx-auto px-4 md:px-8 xl:px-12">
    <div class="flex flex-col gap-1.5 mb-8">
      <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-klano-fog">
        {labelTop.split('·').map((part, i, arr) => (
          <span>{i === arr.length - 1 ? <span class="text-klano-acid">{part.trim()}</span> : part}{i < arr.length - 1 && <span> · </span>}</span>
        ))}
      </span>
      <span class="font-mono text-[11px] tracking-[0.2em] uppercase text-klano-bone">{labelSub}</span>
    </div>

    <div class="massive-mark relative w-full leading-[0.78]">
      <span class="text">kla<span class="o">n</span>o</span>
      <svg
        class="waveform-decoration"
        preserveAspectRatio="none"
        viewBox="0 0 1000 100"
        fill="none"
        aria-hidden="true"
      >
        <line x1="0" y1="50" x2="1000" y2="50" stroke="#46414B" stroke-width="0.5" opacity="0.5"></line>
        <g stroke="#C5F25C" stroke-width="1.5" stroke-linecap="round" opacity="0.7">
          <line x1="50" y1="30" x2="50" y2="70"></line>
          <line x1="125" y1="18" x2="125" y2="82"></line>
          <line x1="200" y1="34" x2="200" y2="66"></line>
          <line x1="290" y1="26" x2="290" y2="74"></line>
          <line x1="365" y1="14" x2="365" y2="86" stroke="#FF5C39"></line>
          <line x1="425" y1="22" x2="425" y2="78"></line>
          <line x1="500" y1="16" x2="500" y2="84" stroke="#FF5C39"></line>
          <line x1="575" y1="26" x2="575" y2="74"></line>
          <line x1="635" y1="20" x2="635" y2="80"></line>
          <line x1="710" y1="24" x2="710" y2="76"></line>
          <line x1="780" y1="32" x2="780" y2="68"></line>
          <line x1="845" y1="36" x2="845" y2="64"></line>
          <line x1="920" y1="44" x2="920" y2="56"></line>
        </g>
        <line x1="365" y1="0" x2="365" y2="100" stroke="#FF5C39" stroke-width="1.2" stroke-dasharray="2 3" opacity="0.8"></line>
      </svg>
    </div>

    <p class="wordmark-caption mt-8 pt-6 border-t border-klano-edge text-base text-klano-bone leading-relaxed max-w-xl">
      {caption.split(/(—.*?\.)/).map((part) => (
        part.startsWith('—') ? <em>{part}</em> : part
      ))}
    </p>
  </div>
</section>

<style>
  .wordmark-section {
    background: linear-gradient(180deg, var(--color-klano-void) 0%, rgba(61, 31, 74, 0.06) 50%, var(--color-klano-void) 100%);
  }
  .massive-mark .text {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 900;
    font-size: clamp(7rem, 33vw, 22rem);
    color: var(--color-klano-pearl);
    letter-spacing: -0.07em;
    display: block;
    position: relative;
    z-index: 2;
  }
  .massive-mark .text .o {
    color: var(--color-klano-coral);
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
  }
  .waveform-decoration {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 60%;
    transform: translateY(-50%);
    z-index: 1;
    pointer-events: none;
    opacity: 0.6;
  }
  .wordmark-caption :global(em) {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100;
    font-style: italic;
    color: var(--color-klano-coral);
  }
</style>
