---
import Container from './Container.astro';
import Logo from './Logo.astro';

interface FooterCol {
  heading: string;
  links: { label: string; href: string }[];
}
interface Props {
  tagline: string;
  cols: readonly FooterCol[];
  legalLeft: string;
  legalRight: string;
}
const { tagline, cols, legalLeft, legalRight } = Astro.props;
---

<footer class="border-t border-klano-border pt-20 pb-12 bg-klano-canvas">
  <Container>
    <div class="grid gap-12 md:grid-cols-[1.5fr_1fr_1fr_1fr] md:gap-16 mb-16">
      <div class="flex flex-col gap-4">
        <Logo />
        <p class="text-sm text-klano-text-2 max-w-[280px] leading-[1.55]">{tagline}</p>
      </div>
      {
        cols.map((col) => (
          <div>
            <h4 class="font-mono text-[11px] uppercase tracking-[0.08em] text-klano-text-3 mb-4 font-medium">
              {col.heading}
            </h4>
            <ul class="space-y-2.5">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="text-sm text-klano-text-2 hover:text-klano-text transition-colors no-underline">
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 pt-8 border-t border-klano-border font-mono text-xs text-klano-text-3">
      <span>{legalLeft}</span>
      <span>{legalRight}</span>
    </div>
  </Container>
</footer>
