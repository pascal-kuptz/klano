---
/**
 * Fixed-position blueprint grid behind everything. 12-column construction guides,
 * very subtle, only visible against dark canvas. Affinity-style.
 */
---

<div class="grid-overlay" aria-hidden="true">
  <div class="grid-inner">
    {Array.from({ length: 13 }).map(() => <span class="col-line"></span>)}
  </div>
</div>

<style>
  .grid-overlay {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    display: flex;
    justify-content: center;
  }
  .grid-inner {
    width: 100%;
    max-width: 1280px;
    height: 100%;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    padding: 0 16px;
  }
  @media (min-width: 768px) {
    .grid-inner { padding: 0 32px; }
  }
  @media (min-width: 1280px) {
    .grid-inner { padding: 0 48px; }
  }
  .col-line {
    border-left: 1px solid rgba(255, 255, 255, 0.025);
    height: 100%;
  }
  .col-line:last-child {
    border-right: 1px solid rgba(255, 255, 255, 0.025);
  }
  /* Very faint on cream sections for continuity */
  :global(.bg-klano-cream) ~ .grid-overlay .col-line {
    border-color: rgba(10, 10, 11, 0.04);
  }
</style>
