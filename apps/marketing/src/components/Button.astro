---
type Variant = 'primary' | 'ghost' | 'dark';

interface Props {
  variant?: Variant;
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
  arrow?: boolean;
}

const { variant = 'primary', href, type = 'button', class: className = '', arrow = false } = Astro.props;

const Tag = href ? 'a' : 'button';
const variantClass: Record<Variant, string> = {
  primary: 'bg-klano-acid text-klano-ink hover:bg-klano-acid-soft',
  ghost: 'bg-transparent text-klano-pearl border border-klano-edge hover:border-klano-pearl hover:bg-klano-card',
  dark: 'bg-klano-ink text-klano-acid border border-klano-ink hover:-translate-y-0.5',
};
---

<Tag
  href={href}
  type={Tag === 'button' ? type : undefined}
  class:list={[
    'inline-flex items-center justify-center gap-2.5 min-h-14 px-7 py-3.5',
    'rounded-[14px] font-semibold text-base tracking-tight',
    'transition-all duration-250 cursor-pointer no-underline',
    'hover:-translate-y-0.5 active:translate-y-0 active:scale-[0.98]',
    variantClass[variant],
    className,
  ]}
>
  <slot />
  {arrow && <span class="arrow inline-block transition-transform duration-200" aria-hidden="true">→</span>}
</Tag>

<style>
  a:hover :global(.arrow),
  button:hover :global(.arrow) {
    transform: translateX(4px);
  }
</style>
