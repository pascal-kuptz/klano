---
import TrackMarker from './TrackMarker.astro';

interface VenueCard {
  rank: string;
  match: string;
  region: string;
  name: string;
  city: string;
  cap: string;
  genre: string;
  verdict: string;
}
interface Props {
  track: string;
  eyebrow: string;
  heading: readonly [string, string];
  lede: string;
  cards: readonly VenueCard[];
}
const { track, eyebrow, heading, lede, cards } = Astro.props;
---

<section class="reveal py-24 lg:py-36">
  <div class="max-w-screen-xl mx-auto px-4 md:px-8 xl:px-12">
    <div class="mb-16 max-w-[820px]">
      <TrackMarker num={track} label={eyebrow} />
      <h2 class="venues-heading mt-6">
        {heading[0]} <em>{heading[1]}</em>
      </h2>
      <p class="text-klano-bone text-base md:text-lg leading-relaxed mt-8 max-w-[520px]">{lede}</p>
    </div>

    <div class="grid gap-5 md:grid-cols-3 md:gap-6 venues-grid">
      {
        cards.map((vc, i) => (
          <article class:list={['vc', i === 0 && 'vc-prime', i === 1 && 'vc-mid', i === 2 && 'vc-tail']}>
            <div class="vc-meta">
              <span class="vc-rank">
                {vc.rank} · <span class="vc-match">Match {vc.match}</span>
              </span>
              <span class="vc-region">{vc.region}</span>
            </div>
            <h3 class="vc-name">{vc.name}</h3>
            <p class="vc-city">{vc.city}</p>
            <div class="vc-stats">
              <span>
                Cap <strong>{vc.cap}</strong>
              </span>
              <span>{vc.genre}</span>
              <span class="vc-verdict">{vc.verdict}</span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .venues-heading {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 800;
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 0.98;
    letter-spacing: -0.04em;
    color: var(--color-klano-pearl);
  }
  .venues-heading em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    color: var(--color-klano-coral);
  }

  .vc {
    background: var(--color-klano-card);
    border: 1px solid var(--color-klano-edge);
    border-radius: 20px;
    padding: 28px;
    transition: all 300ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .vc:hover {
    border-color: var(--color-klano-mist);
    transform: translateY(-4px);
  }
  /* Subtle stagger on desktop only — feels like a fanned-out card hand */
  @media (min-width: 768px) {
    .vc-prime { transform: translateY(-8px); border-color: rgba(197, 242, 92, 0.25); }
    .vc-prime:hover { transform: translateY(-12px); border-color: var(--color-klano-acid); }
    .vc-mid { transform: translateY(8px); }
    .vc-mid:hover { transform: translateY(4px); }
    .vc-tail { transform: translateY(0); }
    .vc-tail:hover { transform: translateY(-4px); }
  }

  .vc-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    margin-bottom: 28px;
  }
  .vc-match {
    color: var(--color-klano-acid);
  }
  .vc-name {
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-klano-pearl);
  }
  .vc-city {
    color: var(--color-klano-sand);
    margin-top: 4px;
    font-size: 14px;
  }
  .vc-stats {
    margin-top: 28px;
    padding-top: 16px;
    border-top: 1px solid var(--color-klano-edge-soft);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-klano-bone);
  }
  .vc-stats strong {
    color: var(--color-klano-pearl);
  }
  .vc-verdict {
    color: var(--color-klano-acid);
    font-weight: 500;
  }
</style>
