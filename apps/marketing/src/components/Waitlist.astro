---
import Container from './Container.astro';
import Button from './Button.astro';
import SectionLabel from './SectionLabel.astro';

interface Props {
  num: string;
  eyebrow: string;
  heading: string;
  subline: string;
  placeholder: string;
  submit: string;
  success: string;
  successPlaceholder: string;
  meta: string;
  locale: 'de' | 'en';
}
const { num, eyebrow, heading, subline, placeholder, submit, success, successPlaceholder, meta, locale } =
  Astro.props;
---

<section id="waitlist" class="py-24 md:py-36 relative overflow-hidden">
  <div class="waitlist-glow" aria-hidden="true"></div>
  <Container width="narrow">
    <div class="text-center relative">
      <div class="flex justify-center mb-6">
        <SectionLabel num={num} label={eyebrow} />
      </div>
      <h2 class="font-display text-[clamp(2rem,4.5vw,3.25rem)] leading-[1.05] tracking-[-0.025em] text-klano-text">
        {heading}
      </h2>
      <p class="mt-5 text-klano-text-2 text-base leading-[1.55] max-w-[560px] mx-auto">{subline}</p>

      <form
        class="mt-10 flex flex-col sm:flex-row gap-2 max-w-[480px] mx-auto"
        data-locale={locale}
        data-success={success}
        data-success-placeholder={successPlaceholder}
      >
        <input
          type="email"
          name="email"
          required
          placeholder={placeholder}
          aria-label="Email"
          class="flex-1 h-12 px-4 bg-klano-surface border border-klano-border rounded-full text-klano-text placeholder:text-klano-text-3 outline-none transition-colors focus:border-klano-text"
        />
        <Button variant="primary" size="lg" type="submit">{submit}</Button>
      </form>

      <p class="mt-5 font-mono text-[11px] uppercase tracking-[0.08em] text-klano-text-3">{meta}</p>
    </div>
  </Container>
</section>

<style>
  .waitlist-glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 60% 70% at 50% 100%, rgba(10, 10, 10, 0.04) 0%, transparent 60%);
  }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-success]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector<HTMLInputElement>('input[name="email"]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (!input || !button) return;

      const email = input.value.trim();
      if (!email) return;

      const successText = form.dataset.success ?? 'You are in.';
      const successPlaceholder = form.dataset.successPlaceholder ?? '';
      const locale = form.dataset.locale ?? 'de';
      const original = button.innerHTML;

      button.disabled = true;
      button.innerHTML = '...';

      try {
        await new Promise((r) => setTimeout(r, 400));
        input.value = '';
        input.placeholder = successPlaceholder;
        button.innerHTML = successText;

        const plausible = (
          window as unknown as {
            plausible?: (event: string, opts?: { props?: Record<string, string> }) => void;
          }
        ).plausible;
        plausible?.('waitlist_signup', { props: { locale } });
      } catch (err) {
        button.disabled = false;
        button.innerHTML = original;
        console.error('waitlist submit failed', err);
      }
    });
  });
</script>
