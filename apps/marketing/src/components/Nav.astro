---
import Logo from './Logo.astro';
import Button from './Button.astro';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  primaryCta: string;
  loginLabel: string;
  links: readonly NavLink[];
  homeHref?: string;
}

const { primaryCta, loginLabel, links, homeHref = '/' } = Astro.props;
const APP_URL = 'https://app.klano.ai';
---

<div class="nav-wrap">
  <nav id="site-nav" class="nav-pill">
    <Logo href={homeHref} class="!text-[22px] nav-logo" />

    <ul class="nav-links" role="list">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="nav-link">
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="nav-actions">
      <a href={`${APP_URL}/sign-in`} class="nav-login">{loginLabel}</a>
      <Button variant="primary" href={`${APP_URL}/onboarding`} size="sm">{primaryCta}</Button>
      <button
        type="button"
        id="nav-burger"
        class="nav-burger"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="7" x2="20" y2="7" />
          <line x1="4" y1="17" x2="20" y2="17" />
        </svg>
      </button>
    </div>
  </nav>
</div>

<!-- Mobile overlay menu -->
<div id="nav-mobile" class="nav-mobile" data-open="false" aria-hidden="true">
  <div class="nav-mobile-inner">
    <div class="nav-mobile-head">
      <Logo href={homeHref} class="!text-[22px]" />
      <button type="button" id="nav-mobile-close" class="nav-mobile-close" aria-label="Menü schließen">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <line x1="6" y1="6" x2="18" y2="18" />
          <line x1="18" y1="6" x2="6" y2="18" />
        </svg>
      </button>
    </div>
    <ul class="nav-mobile-list" role="list">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="nav-mobile-link" data-nav-close>
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="nav-mobile-sep" aria-hidden="true" />
      <li>
        <a href={`${APP_URL}/sign-in`} class="nav-mobile-link nav-mobile-secondary" data-nav-close>
          {loginLabel}
        </a>
      </li>
    </ul>
    <div class="nav-mobile-cta">
      <Button variant="primary" href={`${APP_URL}/onboarding`} size="lg" class="!w-full">
        {primaryCta}
      </Button>
    </div>
  </div>
</div>

<style>
  .nav-wrap {
    position: fixed;
    top: 16px;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding: 0 12px;
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .nav-wrap { top: 20px; padding: 0 32px; }
  }

  .nav-pill {
    pointer-events: auto;
    width: 100%;
    max-width: 1100px;
    height: 60px;
    padding: 8px 8px 8px 22px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 16px;
    border-radius: 9999px;
    background: rgba(250, 250, 250, 0.7);
    border: 1px solid var(--color-klano-border);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: background 200ms, box-shadow 200ms, border-color 200ms;
  }
  .nav-pill.is-scrolled {
    background: rgba(255, 255, 255, 0.85);
    border-color: var(--color-klano-border-strong);
    box-shadow: 0 6px 24px -8px rgba(0, 0, 0, 0.1);
  }
  @media (min-width: 768px) {
    .nav-pill { padding: 8px 8px 8px 28px; }
  }

  .nav-links {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 4px;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  @media (min-width: 900px) {
    .nav-links { display: inline-flex; }
  }

  .nav-link {
    height: 36px;
    padding: 0 12px;
    display: inline-flex;
    align-items: center;
    color: var(--color-klano-text-2);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 9999px;
    transition: color 150ms, background 150ms;
  }
  .nav-link:hover {
    color: var(--color-klano-text);
    background: var(--color-klano-surface-2);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 4px;
    justify-self: end;
  }

  .nav-login {
    height: 44px;
    padding: 0 14px;
    display: none;
    align-items: center;
    color: var(--color-klano-text-2);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 9999px;
    transition: color 150ms, background 150ms;
  }
  .nav-login:hover {
    color: var(--color-klano-text);
    background: var(--color-klano-surface-2);
  }
  @media (min-width: 640px) {
    .nav-login { display: inline-flex; }
  }

  .nav-burger {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    border-radius: 9999px;
    color: var(--color-klano-text);
    cursor: pointer;
    transition: background 150ms;
    margin-left: 4px;
  }
  .nav-burger:hover { background: var(--color-klano-surface-2); }
  .nav-burger svg { width: 22px; height: 22px; }
  @media (min-width: 900px) {
    .nav-burger { display: none; }
  }

  /* Mobile overlay */
  .nav-mobile {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: var(--color-klano-canvas);
    transform: translateY(-100%);
    transition: transform 280ms cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }
  .nav-mobile[data-open='true'] {
    transform: translateY(0);
    pointer-events: auto;
  }
  .nav-mobile-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 16px 16px 24px;
  }
  .nav-mobile-head {
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .nav-mobile-close {
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--color-klano-border);
    border-radius: 9999px;
    color: var(--color-klano-text);
    cursor: pointer;
  }
  .nav-mobile-list {
    flex: 1;
    list-style: none;
    padding: 32px 8px 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .nav-mobile-link {
    display: block;
    padding: 12px 8px;
    color: var(--color-klano-text);
    text-decoration: none;
    font-family: 'Instrument Serif', Georgia, serif;
    font-weight: 400;
    font-size: 28px;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }
  .nav-mobile-link:active { color: var(--color-klano-text-2); }
  .nav-mobile-secondary {
    font-size: 15px;
    font-family: var(--font-sans);
    font-weight: 500;
    color: var(--color-klano-text-2);
    padding-top: 8px;
  }
  .nav-mobile-sep {
    height: 1px;
    background: var(--color-klano-border);
    margin: 16px 8px 8px;
  }
  .nav-mobile-cta {
    padding-top: 16px;
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 12);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  const burger = document.getElementById('nav-burger');
  const overlay = document.getElementById('nav-mobile');
  const close = document.getElementById('nav-mobile-close');

  function setOpen(open: boolean) {
    if (!overlay || !burger) return;
    overlay.dataset.open = open ? 'true' : 'false';
    overlay.setAttribute('aria-hidden', open ? 'false' : 'true');
    burger.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  burger?.addEventListener('click', () => setOpen(true));
  close?.addEventListener('click', () => setOpen(false));
  document.querySelectorAll('[data-nav-close]').forEach((a) =>
    a.addEventListener('click', () => setOpen(false)),
  );
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.dataset.open === 'true') setOpen(false);
  });
</script>
