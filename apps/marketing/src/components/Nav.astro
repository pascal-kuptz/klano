---
import Logo from './Logo.astro';
import Button from './Button.astro';
import Container from './Container.astro';

interface Props {
  primaryCta: string;
  secondaryLabel: string;
  secondaryHref: string;
  homeHref?: string;
}
const { primaryCta, secondaryLabel, secondaryHref, homeHref = '/' } = Astro.props;
---

<nav id="site-nav" class="fixed top-0 inset-x-0 z-50 transition-colors duration-200">
  <Container class="flex items-center justify-between py-4 md:py-5">
    <Logo href={homeHref} />
    <div class="flex items-center gap-2">
      <a href={secondaryHref} class="hidden md:inline-flex h-11 px-4 items-center text-sm text-klano-text-2 hover:text-klano-text transition-colors no-underline">
        {secondaryLabel}
      </a>
      <Button variant="primary" href="#waitlist" size="sm">{primaryCta}</Button>
    </div>
  </Container>
</nav>

<style>
  #site-nav {
    background: rgba(250, 250, 250, 0.7);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
  }
  #site-nav.is-scrolled {
    background: rgba(250, 250, 250, 0.92);
    border-bottom: 1px solid var(--color-klano-border);
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 12);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
