---
import Logo from './Logo.astro';
import Button from './Button.astro';

interface Props {
  primaryCta: string;
  secondaryLabel: string;
  secondaryHref: string;
  homeHref?: string;
}
const { primaryCta, secondaryLabel, secondaryHref, homeHref = '/' } = Astro.props;
---

<div class="nav-wrap">
  <nav id="site-nav" class="nav-pill">
    <Logo href={homeHref} class="!text-[22px]" />
    <div class="nav-actions">
      <a href={secondaryHref} class="hidden md:inline-flex nav-link">{secondaryLabel}</a>
      <Button variant="primary" href="https://app.klano.ai/onboarding" size="sm">{primaryCta}</Button>
    </div>
  </nav>
</div>

<style>
  .nav-wrap {
    position: fixed;
    top: 16px;
    left: 0;
    right: 0;
    z-index: 50;
    display: flex;
    justify-content: center;
    padding: 0 12px;
    pointer-events: none;
  }
  @media (min-width: 768px) {
    .nav-wrap { top: 20px; padding: 0 32px; }
  }

  .nav-pill {
    pointer-events: auto;
    width: 100%;
    max-width: 1200px;
    height: 60px;
    padding: 8px 8px 8px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: 9999px;
    background: rgba(250, 250, 250, 0.7);
    border: 1px solid var(--color-klano-border);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: background 200ms, box-shadow 200ms, border-color 200ms;
  }
  .nav-pill.is-scrolled {
    background: rgba(255, 255, 255, 0.85);
    border-color: var(--color-klano-border-strong);
    box-shadow: 0 6px 24px -8px rgba(0, 0, 0, 0.1);
  }
  @media (min-width: 768px) {
    .nav-pill { padding: 8px 8px 8px 28px; }
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-link {
    height: 44px;
    padding: 0 14px;
    display: inline-flex;
    align-items: center;
    color: var(--color-klano-text-2);
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 9999px;
    transition: color 150ms, background 150ms;
  }
  .nav-link:hover {
    color: var(--color-klano-text);
    background: var(--color-klano-surface-2);
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const onScroll = () => nav.classList.toggle('is-scrolled', window.scrollY > 12);
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
</script>
