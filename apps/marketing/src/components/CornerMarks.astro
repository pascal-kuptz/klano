---
/**
 * Four blueprint-style corner crosshairs that frame a section. Pure presentational,
 * gives every section a "this is constructed" feel — like Figma artboard pins.
 */
interface Props {
  variant?: 'default' | 'cream';
}
const { variant = 'default' } = Astro.props;
---

<div class:list={['corner-marks', variant === 'cream' && 'is-cream']} aria-hidden="true">
  <span class="cm cm-tl"></span>
  <span class="cm cm-tr"></span>
  <span class="cm cm-bl"></span>
  <span class="cm cm-br"></span>
</div>

<style>
  .corner-marks {
    position: absolute;
    inset: 16px;
    pointer-events: none;
    color: var(--color-klano-edge);
  }
  .corner-marks.is-cream {
    color: rgba(10, 10, 11, 0.15);
  }
  .cm {
    position: absolute;
    width: 14px;
    height: 14px;
  }
  .cm::before,
  .cm::after {
    content: '';
    position: absolute;
    background: currentColor;
  }
  .cm::before {
    width: 100%;
    height: 1px;
    top: 50%;
  }
  .cm::after {
    width: 1px;
    height: 100%;
    left: 50%;
  }
  .cm-tl { top: 0; left: 0; }
  .cm-tr { top: 0; right: 0; }
  .cm-bl { bottom: 0; left: 0; }
  .cm-br { bottom: 0; right: 0; }
  @media (min-width: 1024px) {
    .corner-marks { inset: 32px; }
    .cm { width: 18px; height: 18px; }
  }
</style>
