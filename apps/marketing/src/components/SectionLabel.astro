---
interface Props {
  num: string;
  label: string;
  class?: string;
}
const { num, label, class: className = '' } = Astro.props;
---

<div class:list={['inline-flex items-center gap-3', className]}>
  <span class="font-mono text-[11px] tracking-[0.04em] text-klano-text-3 tabular-nums">
    {num}
  </span>
  <span class="h-px w-6 bg-klano-border-strong" aria-hidden="true"></span>
  <span class="font-mono text-[11px] uppercase tracking-[0.08em] text-klano-text-2">
    {label}
  </span>
</div>
