---
interface Props {
  href?: string;
  size?: number;
  class?: string;
}
const { href = '/', size = 44, class: className = '' } = Astro.props;
---

<a
  href={href}
  class:list={['mark', className]}
  style={`font-size:${size}px`}
  aria-label="Klano"
>
  k
</a>

<style>
  .mark {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-weight: 400;
    line-height: 0.7;
    letter-spacing: -0.06em;
    color: var(--color-klano-pearl);
    text-decoration: none;
    display: inline-block;
    position: relative;
    transition: transform 300ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .mark:hover {
    transform: rotate(-3deg) scale(1.05);
  }
  .mark::after {
    content: '';
    position: absolute;
    bottom: 6px;
    right: -10px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-klano-coral);
    box-shadow: 0 0 10px var(--color-klano-coral);
    animation: blip 2.4s ease-in-out infinite;
  }
  @keyframes blip {
    0%,
    100% {
      opacity: 0.7;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.4);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .mark::after {
      animation: none;
    }
  }
</style>
