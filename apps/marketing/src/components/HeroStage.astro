---
import CornerBrackets from './CornerBrackets.astro';

interface Props {
  caption?: string;
  detail?: string;
  /** Ratio fallback for short screens; the height is clamp-driven for tall ones. */
  ratio?: string;
}
const { caption = 'header image', detail = 'Zürich · backstage · 23:14', ratio = '21/9' } = Astro.props;
---

<div class="stage-wrap relative">
  <CornerBrackets />
  <figure class="stage" style={`aspect-ratio: ${ratio};`} role="img" aria-label={caption}>
    <div class="stage-bg" aria-hidden="true"></div>
    <div class="stage-grid" aria-hidden="true"></div>

    <div class="stage-caption stage-caption-tl">
      <span class="dot"></span>
      <span>{caption}</span>
    </div>
    <div class="stage-caption stage-caption-tr">
      <span>1920 × 1080</span>
    </div>
    <div class="stage-caption stage-caption-bl">
      <span>{detail}</span>
    </div>
    <div class="stage-caption stage-caption-br">
      <span>klano · 00</span>
    </div>

    <div class="stage-center" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="9" cy="9" r="2" />
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
      </svg>
    </div>
  </figure>
</div>

<style>
  .stage-wrap {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 16px;
  }
  @media (min-width: 768px) { .stage-wrap { padding: 0 32px; } }
  @media (min-width: 1280px) { .stage-wrap { padding: 0 48px; } }

  .stage {
    position: relative;
    width: 100%;
    min-height: clamp(380px, 66vh, 760px);
    border: 1px solid var(--color-klano-border);
    border-radius: 24px;
    overflow: hidden;
    margin: 0;
    background: var(--color-klano-surface);
  }

  /* Subtle layered gradient — preview of "image will go here" */
  .stage-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 70% 20%, rgba(10, 10, 10, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 20% 80%, rgba(10, 10, 10, 0.04) 0%, transparent 70%),
      linear-gradient(135deg, var(--color-klano-surface) 0%, var(--color-klano-surface-2) 60%, var(--color-klano-canvas) 100%);
  }

  /* Faint blueprint grid inside the stage */
  .stage-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(10, 10, 10, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10, 10, 10, 0.05) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: -1px -1px;
    -webkit-mask-image: radial-gradient(ellipse 70% 55% at 50% 50%, black 30%, transparent 80%);
    mask-image: radial-gradient(ellipse 70% 55% at 50% 50%, black 30%, transparent 80%);
  }

  .stage-caption {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    color: var(--color-klano-text-3);
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid var(--color-klano-border);
    border-radius: 999px;
    padding: 6px 12px;
  }
  .stage-caption-tl { top: 16px; left: 16px; }
  .stage-caption-tr { top: 16px; right: 16px; }
  .stage-caption-bl { bottom: 16px; left: 16px; }
  .stage-caption-br { bottom: 16px; right: 16px; }
  @media (min-width: 768px) {
    .stage-caption-tl { top: 24px; left: 24px; }
    .stage-caption-tr { top: 24px; right: 24px; }
    .stage-caption-bl { bottom: 24px; left: 24px; }
    .stage-caption-br { bottom: 24px; right: 24px; }
  }
  .stage-caption .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--color-klano-success);
    box-shadow: 0 0 6px rgba(16, 185, 129, 0.5);
  }

  .stage-center {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-klano-text-3);
    pointer-events: none;
  }
  .stage-center svg {
    width: 32px;
    height: 32px;
    opacity: 0.5;
  }
</style>
