---
import Button from './Button.astro';

interface Props {
  observed: string;
  lines: readonly [string, string, string];
  tagline: string;
  ctaPrimary: string;
  ctaSecondary: string;
  meta: string;
}
const { observed, lines, tagline, ctaPrimary, ctaSecondary, meta } = Astro.props;
---

<section class="hero relative min-h-[92vh] flex flex-col justify-center pt-36 pb-20 md:pt-44 md:pb-28">
  <div class="hero-bg absolute inset-0 pointer-events-none" aria-hidden="true"></div>

  <div class="max-w-screen-xl mx-auto w-full px-4 md:px-8 xl:px-12 relative z-[2]">
    <span class="hero-observed">
      <span class="dot" aria-hidden="true"></span>
      {observed}
    </span>

    <h1 class="display-serif mt-10 md:mt-14">
      <span class="line"><span>{lines[0]}</span></span>
      <span class="line"><span><em>{lines[1]}</em></span></span>
      <span class="line"
        ><span>{lines[2].replace(/\.$/, '')}<span class="stop">.</span></span>
      </span>
    </h1>

    <p class="hero-tagline mt-10 max-w-xl">
      {tagline}
    </p>

    <div class="hero-actions mt-12 flex flex-wrap items-center gap-3">
      <Button variant="primary" href="#waitlist" arrow>{ctaPrimary}</Button>
      <a href="#how" class="hero-text-link">
        {ctaSecondary}
        <span class="arrow" aria-hidden="true">↓</span>
      </a>
    </div>

    <div class="hero-meta mt-20 md:mt-32 pt-6 border-t border-klano-edge-soft flex items-center justify-between font-mono text-[11px] tracking-[0.18em] uppercase text-klano-fog">
      <span>{meta}</span>
      <span class="hidden md:inline-flex items-center gap-2">
        <span class="ticker-dot" aria-hidden="true"></span>
        Klano · v0
      </span>
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 60% 50% at 90% 0%, rgba(61, 31, 74, 0.45) 0%, transparent 60%),
      radial-gradient(ellipse 40% 35% at 5% 100%, rgba(197, 242, 92, 0.04) 0%, transparent 70%);
  }

  .hero-observed {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-klano-sand);
  }
  .hero-observed .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-klano-coral);
    box-shadow: 0 0 8px var(--color-klano-coral);
    animation: blip 2.4s ease-in-out infinite;
  }
  @keyframes blip {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.3); }
  }

  .display-serif {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.045em;
    font-size: clamp(3.5rem, 14vw, 9rem);
  }
  .display-serif em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    color: var(--color-klano-coral);
  }
  .display-serif .stop {
    color: var(--color-klano-acid);
  }
  .display-serif .line {
    display: block;
    overflow: hidden;
  }
  .display-serif .line > span {
    display: inline-block;
    transform: translateY(110%);
    animation: rise 1.1s cubic-bezier(0.25, 1, 0.5, 1) both;
  }
  .display-serif .line:nth-child(1) > span { animation-delay: 0.1s; }
  .display-serif .line:nth-child(2) > span { animation-delay: 0.24s; }
  .display-serif .line:nth-child(3) > span { animation-delay: 0.4s; }
  @keyframes rise { to { transform: translateY(0); } }

  .hero-tagline {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 50, 'WONK' 0;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.125rem, 1.8vw, 1.375rem);
    line-height: 1.45;
    color: var(--color-klano-bone);
    opacity: 0;
    animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 0.85s forwards;
  }

  .hero-actions {
    opacity: 0;
    animation: fadeUp 1s cubic-bezier(0.25, 1, 0.5, 1) 1s forwards;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero-text-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-klano-bone);
    font-family: 'Geist Variable', system-ui, sans-serif;
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    padding: 12px 4px;
    border-bottom: 1px solid transparent;
    transition: all 200ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hero-text-link:hover {
    color: var(--color-klano-pearl);
    border-bottom-color: var(--color-klano-acid);
  }
  .hero-text-link .arrow {
    transition: transform 200ms cubic-bezier(0.25, 1, 0.5, 1);
  }
  .hero-text-link:hover .arrow {
    transform: translateY(2px);
  }

  .ticker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-klano-acid);
    box-shadow: 0 0 6px var(--color-klano-acid);
  }

  @media (prefers-reduced-motion: reduce) {
    .display-serif .line > span,
    .hero-tagline,
    .hero-actions,
    .hero-observed .dot {
      animation: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>
