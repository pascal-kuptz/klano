---
import Container from './Container.astro';
import Button from './Button.astro';

interface Props {
  badge: string;
  headline: string;
  headlineItalic?: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { badge, headline, headlineItalic, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="hero relative min-h-[88vh] flex items-center justify-center pt-32 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Stage layers (background — swap <img> with own photo later) -->
  <div class="hero-stage" aria-hidden="true">
    <img
      class="hero-stage-img"
      src="https://images.unsplash.com/photo-1429962714451-bb934ecdc4ec?w=2400&q=80&auto=format&fit=crop"
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
      referrerpolicy="no-referrer"
    />
    <div class="hero-stage-tint"></div>
    <div class="hero-stage-grid"></div>
    <div class="hero-stage-vignette"></div>
  </div>

  <Container>
    <div class="flex flex-col items-center text-center max-w-[860px] mx-auto relative z-[3]">
      <span
        class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-klano-surface/80 backdrop-blur border border-klano-border text-[12px] text-klano-text-2 font-mono tracking-tight mb-8"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-klano-success"></span>
        {badge}
      </span>

      <h1 class="font-display text-[clamp(2.75rem,7vw,5rem)] leading-[1.02] tracking-[-0.025em] text-klano-text">
        {headline}
        {headlineItalic && <span class="italic text-klano-text-2"> {headlineItalic}</span>}
      </h1>

      <p class="mt-7 text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.55] text-klano-text-2 max-w-[640px]">
        {subline}
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <Button variant="primary" size="lg" href="#waitlist">{ctaPrimary}</Button>
        <Button variant="secondary" size="lg" href="#features">{ctaSecondary}</Button>
      </div>
    </div>
  </Container>
</section>

<style>
  /* === Stage background — placeholder image; swap with own photo later === */
  .hero-stage {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: var(--color-klano-canvas);
  }
  .hero-stage-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    /* Light-theme blend: desaturate slightly so colorful photos don't fight UI */
    filter: saturate(0.85) contrast(0.95);
  }
  /* Soft cream tint over photo so it reads as part of light theme */
  .hero-stage-tint {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(250, 250, 250, 0.45) 0%, rgba(250, 250, 250, 0.78) 100%);
  }
  .hero-stage-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(10, 10, 10, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10, 10, 10, 0.05) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: -1px -1px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 20%, transparent 80%);
    opacity: 0.6;
  }
  /* Center vignette keeps focus on the text without over-whitening the photo */
  .hero-stage-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 45% at 50% 55%, rgba(250, 250, 250, 0.55) 0%, transparent 75%);
  }

</style>
