---
import Container from './Container.astro';
import Button from './Button.astro';

interface Props {
  badge: string;
  headline: string;
  headlineItalic?: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { badge, headline, headlineItalic, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="hero relative min-h-[88vh] flex items-center justify-center pt-32 pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <!-- Stage layers (background — drop <img> here later) -->
  <div class="hero-stage" aria-hidden="true">
    <div class="hero-stage-bg"></div>
    <div class="hero-stage-grid"></div>
    <div class="hero-stage-vignette"></div>
  </div>

  <Container>
    <div class="flex flex-col items-center text-center max-w-[860px] mx-auto relative z-[3]">
      <span
        class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-klano-surface/80 backdrop-blur border border-klano-border text-[12px] text-klano-text-2 font-mono tracking-tight mb-8"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-klano-success"></span>
        {badge}
      </span>

      <h1 class="font-display text-[clamp(2.75rem,7vw,5rem)] leading-[1.02] tracking-[-0.025em] text-klano-text">
        {headline}
        {headlineItalic && <span class="italic text-klano-text-2"> {headlineItalic}</span>}
      </h1>

      <p class="mt-7 text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.55] text-klano-text-2 max-w-[640px]">
        {subline}
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <Button variant="primary" size="lg" href="#waitlist">{ctaPrimary}</Button>
        <Button variant="secondary" size="lg" href="#features">{ctaSecondary}</Button>
      </div>
    </div>
  </Container>
</section>

<style>
  /* === Stage background — placeholder layers; swap .hero-stage-bg for <img> === */
  .hero-stage {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }
  .hero-stage-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 50% 60% at 75% 25%, rgba(10, 10, 10, 0.05) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 20% 90%, rgba(10, 10, 10, 0.04) 0%, transparent 70%),
      linear-gradient(135deg, var(--color-klano-canvas) 0%, var(--color-klano-surface-2) 60%, var(--color-klano-canvas) 100%);
  }
  .hero-stage-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(10, 10, 10, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(10, 10, 10, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    background-position: -1px -1px;
    -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 90%);
    mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 30%, transparent 90%);
  }
  .hero-stage-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 50% 55%, rgba(255, 255, 255, 0.55) 0%, transparent 70%);
  }

</style>
