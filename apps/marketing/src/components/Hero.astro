---
import Container from './Container.astro';
import Button from './Button.astro';

interface Props {
  badge: string;
  headline: string;
  /** italicized tail after the headline, optional — Instrument Serif italic */
  headlineItalic?: string;
  subline: string;
  ctaPrimary: string;
  ctaSecondary: string;
}
const { badge, headline, headlineItalic, subline, ctaPrimary, ctaSecondary } = Astro.props;
---

<section class="pt-32 pb-12 md:pt-36 md:pb-16 relative overflow-hidden">
  <div class="hero-glow" aria-hidden="true"></div>
  <Container>
    <div class="flex flex-col items-center text-center max-w-[860px] mx-auto relative">
      <span
        class="inline-flex items-center gap-2 h-7 px-3 rounded-full bg-klano-surface border border-klano-border text-[12px] text-klano-text-2 font-mono tracking-tight mb-8"
      >
        <span class="w-1.5 h-1.5 rounded-full bg-klano-success"></span>
        {badge}
      </span>

      <h1 class="font-display text-[clamp(2.75rem,7vw,5rem)] leading-[1.02] tracking-[-0.025em] text-klano-text">
        {headline}
        {headlineItalic && <span class="italic text-klano-text-2"> {headlineItalic}</span>}
      </h1>

      <p class="mt-7 text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.55] text-klano-text-2 max-w-[640px]">
        {subline}
      </p>

      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <Button variant="primary" size="lg" href="#waitlist">{ctaPrimary}</Button>
        <Button variant="secondary" size="lg" href="#features">{ctaSecondary}</Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-glow {
    position: absolute;
    inset: -10% -10% auto -10%;
    height: 80%;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 60% at 50% 0%, rgba(10, 10, 10, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse 80% 40% at 50% 100%, rgba(255, 255, 255, 0.6) 0%, transparent 70%);
  }
</style>
