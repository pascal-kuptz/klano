---
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';

interface Stat {
  num: string;
  em: string;
  label: string;
}

interface Props {
  eyebrow: string;
  lines: readonly [string, string, string];
  ctaPrimary: string;
  ctaSecondary: string;
  stats: readonly Stat[];
}
const { eyebrow, lines, ctaPrimary, ctaSecondary, stats } = Astro.props;
---

<section class="hero relative min-h-screen flex flex-col justify-center pt-36 pb-20 md:pt-48 md:pb-28">
  <div class="hero-bg absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="max-w-screen-xl mx-auto w-full px-4 md:px-8 xl:px-12 relative z-[2]">
    <Eyebrow class="mb-8 md:mb-14">{eyebrow}</Eyebrow>

    <h1 class="display-serif">
      <span class="line"><span>{lines[0]}</span></span>
      <span class="line"><span><em>{lines[1]}</em></span></span>
      <span class="line"
        ><span>{lines[2].replace(/\.$/, '')}<span class="stop">.</span></span>
      </span>
    </h1>

    <div class="hero-meta mt-14 md:mt-20 grid gap-8 md:grid-cols-[5fr_4fr_3fr] md:items-end md:gap-12">
      <div class="flex flex-wrap gap-3">
        <Button variant="primary" href="#waitlist" arrow>{ctaPrimary}</Button>
        <Button variant="ghost" href="#how">{ctaSecondary}</Button>
      </div>
      {
        stats.map((s) => (
          <div class="hero-stat">
            <span class="num">
              {s.num}
              <em>{s.em}</em>
            </span>
            <span class="lbl">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 70% 60% at 90% 5%, rgba(61, 31, 74, 0.5) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 5% 100%, rgba(197, 242, 92, 0.05) 0%, transparent 70%);
  }
  .display-serif {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.04em;
    font-size: clamp(4rem, 16vw, 10rem);
  }
  .display-serif em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
  }
  .display-serif .stop {
    color: var(--color-klano-acid);
  }
  .display-serif .line {
    display: block;
    overflow: hidden;
  }
  .display-serif .line > span {
    display: inline-block;
    transform: translateY(110%);
    animation: rise 1.1s cubic-bezier(0.25, 1, 0.5, 1) both;
  }
  .display-serif .line:nth-child(1) > span {
    animation-delay: 0.05s;
  }
  .display-serif .line:nth-child(2) > span {
    animation-delay: 0.18s;
  }
  .display-serif .line:nth-child(3) > span {
    animation-delay: 0.32s;
  }
  @keyframes rise {
    to {
      transform: translateY(0);
    }
  }

  .hero-meta {
    opacity: 0;
    animation: fadeUp 1.1s cubic-bezier(0.25, 1, 0.5, 1) 0.7s forwards;
  }
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(28px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-stat .num {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 0, 'WONK' 0;
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.045em;
    color: var(--color-klano-pearl);
    line-height: 0.85;
    display: block;
  }
  .hero-stat .num em {
    font-style: italic;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-weight: 400;
    color: var(--color-klano-coral);
  }
  .hero-stat .lbl {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
    margin-top: 12px;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .display-serif .line > span,
    .hero-meta {
      animation: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>
