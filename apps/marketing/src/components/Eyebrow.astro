---
interface Props {
  variant?: 'acid' | 'coral' | 'dark';
  class?: string;
}
const { variant = 'acid', class: className = '' } = Astro.props;

const colorMap = {
  acid: 'before:bg-klano-acid text-klano-fog',
  coral: 'before:bg-klano-coral text-klano-coral',
  dark: 'before:bg-klano-ink text-[rgba(10,10,11,0.55)]',
};
---

<span
  class:list={[
    'inline-flex items-center gap-3 font-mono text-[11px] tracking-[0.22em] uppercase',
    'before:content-[""] before:w-6 before:h-px',
    colorMap[variant],
    className,
  ]}
>
  <slot />
</span>
