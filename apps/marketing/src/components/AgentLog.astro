---
import TrackMarker from './TrackMarker.astro';

interface LogEntry {
  time: string;
  verb: string;
  object: string;
  tone?: 'acid' | 'default';
}
interface Props {
  track: string;
  heading: string;
  sub: string;
  timestamp: string;
  band: string;
  entries: readonly LogEntry[];
  footnote: string;
}
const { track, heading, sub, timestamp, band, entries, footnote } = Astro.props;
---

<section class="reveal py-24 lg:py-36 relative">
  <div class="max-w-screen-xl mx-auto px-4 md:px-8 xl:px-12 grid gap-12 lg:grid-cols-[5fr_7fr] lg:gap-20 lg:items-start">
    <div class="lg:sticky lg:top-32">
      <TrackMarker num={track} label="Agent log" />
      <h2 class="agent-heading mt-6">
        {heading}<br /><em>{sub}</em>
      </h2>
      <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-klano-fog mt-8">
        {timestamp}
      </p>
      <p class="font-mono text-[11px] tracking-[0.18em] uppercase text-klano-bone mt-1">
        {band}
      </p>
    </div>

    <ol class="agent-list">
      {
        entries.map((e) => (
          <li class:list={['agent-row', e.tone === 'acid' && 'is-acid']}>
            <span class="time">{e.time}</span>
            <span class="dot" aria-hidden="true"></span>
            <span class="body">
              <span class="verb">{e.verb}</span>
              <span class="object">{e.object}</span>
            </span>
          </li>
        ))
      }
    </ol>
  </div>

  <p class="max-w-screen-xl mx-auto px-4 md:px-8 xl:px-12 mt-14 lg:mt-20 text-klano-sand text-base md:text-lg max-w-2xl leading-relaxed">
    <em class="agent-footnote-em">{footnote}</em>
  </p>
</section>

<style>
  .agent-heading {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 30, 'WONK' 1;
    font-weight: 800;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.0;
    letter-spacing: -0.03em;
    color: var(--color-klano-pearl);
  }
  .agent-heading em {
    font-style: italic;
    font-weight: 400;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    color: var(--color-klano-coral);
  }

  .agent-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-klano-edge-soft);
  }
  .agent-row {
    display: grid;
    grid-template-columns: 64px 12px 1fr;
    gap: 12px;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-klano-edge-soft);
    align-items: baseline;
  }
  @media (min-width: 768px) {
    .agent-row {
      grid-template-columns: 80px 16px 1fr;
      padding: 22px 0;
    }
  }

  .agent-row .time {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-klano-fog);
  }
  .agent-row .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-klano-mist);
    align-self: center;
    margin-top: 2px;
  }
  .agent-row.is-acid .dot {
    background: var(--color-klano-acid);
    box-shadow: 0 0 8px rgba(197, 242, 92, 0.5);
  }
  .agent-row .body {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: baseline;
  }
  .agent-row .verb {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-weight: 500;
    color: var(--color-klano-pearl);
    font-size: 16px;
    flex-shrink: 0;
  }
  .agent-row .object {
    color: var(--color-klano-bone);
    font-size: 15px;
    line-height: 1.45;
  }
  .agent-row.is-acid .verb {
    color: var(--color-klano-acid);
  }

  .agent-footnote-em {
    font-family: 'Fraunces Variable', Georgia, serif;
    font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
    font-style: italic;
    font-weight: 400;
    color: var(--color-klano-pearl);
  }
</style>
