---
/**
 * Vinyl-tracklist style section anchor — "01 · " marker that sits in the gutter
 * on desktop and as a thin inline label on mobile. Identity element: ties every
 * section back to the editorial-magazine / record-tracklist metaphor.
 */
interface Props {
  num: string;
  label: string;
  variant?: 'default' | 'cream';
}
const { num, label, variant = 'default' } = Astro.props;
---

<div class:list={['track-marker', variant === 'cream' && 'is-cream']}>
  <span class="num">{num}</span>
  <span class="line" aria-hidden="true"></span>
  <span class="label">{label}</span>
</div>

<style>
  .track-marker {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-klano-fog);
  }
  .track-marker .num {
    color: var(--color-klano-acid);
    font-weight: 500;
  }
  .track-marker .line {
    display: inline-block;
    width: 32px;
    height: 1px;
    background: currentColor;
    opacity: 0.4;
  }
  .track-marker.is-cream {
    color: rgba(10, 10, 11, 0.55);
  }
  .track-marker.is-cream .num {
    color: var(--color-klano-ink);
  }
</style>
