---
import Container from './Container.astro';
import Button from './Button.astro';
import SectionLabel from './SectionLabel.astro';

interface Plan {
  name: string;
  price: string;
  priceMeta: string;
  description: string;
  features: string[];
  cta: string;
  ctaHref: string;
  highlight?: boolean;
}
interface Props {
  num: string;
  eyebrow: string;
  heading: string;
  cards: readonly Plan[];
}
const { num, eyebrow, heading, cards } = Astro.props;
---

<section id="pricing" class="py-24 md:py-36 bg-klano-surface-2 border-y border-klano-border relative">
  <Container>
    <div class="max-w-[720px] mb-16 md:mb-20">
      <SectionLabel num={num} label={eyebrow} class="mb-6" />
      <h2 class="font-display text-[clamp(2rem,4vw,3rem)] leading-[1.05] tracking-[-0.02em] text-klano-text">
        {heading}
      </h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3 md:gap-5">
      {
        cards.map((card) => (
          <article class:list={['plan', card.highlight && 'plan-highlight']}>
            <div class="plan-head">
              <span class="plan-name">{card.name}</span>
              {card.highlight && <span class="plan-badge">Limited</span>}
            </div>
            <div class="plan-price-row">
              <span class="plan-price">{card.price}</span>
              <span class="plan-price-meta">{card.priceMeta}</span>
            </div>
            <p class="plan-desc">{card.description}</p>
            <ul class="plan-features">
              {card.features.map((f) => (
                <li>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <Button
              variant={card.highlight ? 'primary' : 'secondary'}
              href={card.ctaHref}
              size="md"
              class="!w-full"
            >
              {card.cta}
            </Button>
          </article>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .plan {
    background: var(--color-klano-surface);
    border: 1px solid var(--color-klano-border);
    border-radius: 20px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms, transform 200ms;
  }
  @media (min-width: 768px) {
    .plan { padding: 36px 32px; }
  }
  .plan:hover {
    border-color: var(--color-klano-border-strong);
  }
  .plan-highlight {
    border-color: var(--color-klano-text);
    box-shadow: 0 0 0 1px var(--color-klano-text);
  }

  .plan-head {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
  }
  .plan-name {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-klano-text-2);
    font-weight: 500;
  }
  .plan-highlight .plan-name {
    color: var(--color-klano-text);
  }
  .plan-badge {
    height: 22px;
    padding: 0 10px;
    border-radius: 999px;
    background: var(--color-klano-text);
    color: var(--color-klano-action-fg);
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: inline-flex; align-items: center;
  }

  .plan-price-row {
    display: flex; align-items: baseline; gap: 8px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-klano-border);
    margin-bottom: 24px;
  }
  .plan-price {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--color-klano-text);
  }
  .plan-price-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-klano-text-3);
  }

  .plan-desc {
    color: var(--color-klano-text-2);
    font-size: 14px;
    line-height: 1.55;
    margin-bottom: 24px;
  }
  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex-grow: 1;
  }
  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--color-klano-text);
    font-size: 14px;
    line-height: 1.45;
  }
  .plan-features svg {
    width: 16px; height: 16px;
    color: var(--color-klano-text-2);
    flex-shrink: 0;
    margin-top: 2px;
  }
</style>
