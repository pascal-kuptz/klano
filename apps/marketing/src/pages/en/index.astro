---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Demo from '../../components/Demo.astro';
import Features from '../../components/Features.astro';
import Plans from '../../components/Plans.astro';
import Waitlist from '../../components/Waitlist.astro';
import Footer from '../../components/Footer.astro';
import { copy } from '../../lib/copy';
import { SITE } from '../../lib/seo';

const c = copy.en;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Klano?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Klano is an AI booking agent for bands. It finds the right venues, drafts outreach emails, and follows up automatically.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does Klano cost?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Free forever. Pro at 19 CHF/EUR/USD per month or 190/year (save 17%). 14-day Pro trial, no credit card.',
      },
    },
    {
      '@type': 'Question',
      name: 'Where does Klano work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Klano launches in the DACH region (Switzerland, Germany, Austria) with a curated venue database for that market.',
      },
    },
  ],
};
---

<Base title={SITE.tagline.en} description={SITE.description.en} jsonLd={[faqJsonLd]}>
  <Nav
    primaryCta={c.nav.primaryCta}
    secondaryLabel={c.nav.secondaryLabel}
    secondaryHref="#features"
    homeHref="/en"
  />
  <main>
    <Hero
      badge={c.hero.badge}
      headline={c.hero.headline}
      headlineItalic={c.hero.headlineItalic}
      subline={c.hero.subline}
      ctaPrimary={c.hero.ctaPrimary}
      ctaSecondary={c.hero.ctaSecondary}
    />
    <Demo
      bandLabel={c.demo.bandLabel}
      statsLabel={c.demo.statsLabel}
      cols={c.demo.cols}
      rows={c.demo.rows}
      aiLabel={c.demo.aiLabel}
      aiText={c.demo.aiText}
      aiCta={c.demo.aiCta}
    />
    <Features eyebrow={c.features.eyebrow} heading={c.features.heading} cards={c.features.cards} />
    <Plans eyebrow={c.plans.eyebrow} heading={c.plans.heading} cards={c.plans.cards} />
    <Waitlist
      eyebrow={c.waitlist.eyebrow}
      heading={c.waitlist.heading}
      subline={c.waitlist.subline}
      placeholder={c.waitlist.placeholder}
      submit={c.waitlist.submit}
      success={c.waitlist.success}
      successPlaceholder={c.waitlist.successPlaceholder}
      meta={c.waitlist.meta}
      locale="en"
    />
  </main>
  <Footer
    tagline={c.footer.tagline}
    cols={c.footer.cols}
    legalLeft={c.footer.legalLeft}
    legalRight={c.footer.legalRight}
  />
</Base>
