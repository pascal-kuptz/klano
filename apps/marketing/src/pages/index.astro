---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Demo from '../components/Demo.astro';
import Features from '../components/Features.astro';
import Plans from '../components/Plans.astro';
import Personal from '../components/Personal.astro';
import Waitlist from '../components/Waitlist.astro';
import Footer from '../components/Footer.astro';
import { copy } from '../lib/copy';
import { SITE } from '../lib/seo';

const c = copy.de;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Was ist Klano?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Klano ist ein KI-Booking-Agent für Bands. Er sucht passende Venues, schreibt Outreach-Mails und hakt automatisch nach.',
      },
    },
    {
      '@type': 'Question',
      name: 'Was kostet Klano?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Free permanent kostenlos. Pro 19 CHF/Monat oder 190 CHF/Jahr (17% Rabatt). 14 Tage Pro-Trial ohne Kreditkarte.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wo funktioniert Klano?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Klano startet in DACH (Schweiz, Deutschland, Österreich) mit einer kuratierten Venue-Datenbank für die Region.',
      },
    },
  ],
};
---

<Base title={SITE.tagline.de} description={SITE.description.de} jsonLd={[faqJsonLd]}>
  <Nav primaryCta={c.nav.primaryCta} secondaryLabel={c.nav.secondaryLabel} secondaryHref="#features" homeHref="/" />
  <main>
    <Hero
      badge={c.hero.badge}
      headline={c.hero.headline}
      headlineItalic={c.hero.headlineItalic}
      subline={c.hero.subline}
      ctaPrimary={c.hero.ctaPrimary}
      ctaSecondary={c.hero.ctaSecondary}
    />
    <Demo
      num={c.demo.num}
      sectionLabel={c.demo.sectionLabel}
      bandLabel={c.demo.bandLabel}
      statsLabel={c.demo.statsLabel}
      cols={c.demo.cols}
      rows={c.demo.rows}
      aiLabel={c.demo.aiLabel}
      aiText={c.demo.aiText}
      aiCta={c.demo.aiCta}
    />
    <Features
      num={c.features.num}
      eyebrow={c.features.eyebrow}
      heading={c.features.heading}
      cards={c.features.cards}
      shotCaptions={{
        hero: 'app.klano.ai/venues',
        inbox: 'app.klano.ai/inbox',
        sync: 'app.klano.ai/sync',
      }}
    />
    <Plans num={c.plans.num} eyebrow={c.plans.eyebrow} heading={c.plans.heading} cards={c.plans.cards} />
    <Personal
      num={c.personal.num}
      eyebrow={c.personal.eyebrow}
      heading={c.personal.heading}
      body={c.personal.body}
      signoff={c.personal.signoff}
      people={c.personal.people}
    />
    <Waitlist
      num={c.waitlist.num}
      eyebrow={c.waitlist.eyebrow}
      heading={c.waitlist.heading}
      subline={c.waitlist.subline}
      placeholder={c.waitlist.placeholder}
      submit={c.waitlist.submit}
      success={c.waitlist.success}
      successPlaceholder={c.waitlist.successPlaceholder}
      meta={c.waitlist.meta}
      locale="de"
    />
  </main>
  <Footer
    tagline={c.footer.tagline}
    cols={c.footer.cols}
    legalLeft={c.footer.legalLeft}
    legalRight={c.footer.legalRight}
  />
</Base>
