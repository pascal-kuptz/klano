---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Container from '../components/Container.astro';
import { copy } from '../lib/copy';
import type { Locale } from '../lib/seo';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
}
const { title, description, locale } = Astro.props;
const c = copy[locale];
---

<Base title={title} description={description}>
  <Nav
    primaryCta={c.nav.primaryCta}
    loginLabel={c.nav.loginLabel}
    links={c.nav.links}
    homeHref={locale === 'de' ? '/' : '/en'}
  />
  <main class="pt-36 pb-20 md:pt-44 md:pb-28">
    <Container width="narrow">
      <h1 class="font-display text-[clamp(2.25rem,5vw,3.25rem)] leading-[1.05] tracking-[-0.025em] mb-12">
        {title}
      </h1>
      <div class="prose-klano">
        <slot />
      </div>
    </Container>
  </main>
  <Footer
    tagline={c.footer.tagline}
    cols={c.footer.cols}
    legalLeft={c.footer.legalLeft}
    legalRight={c.footer.legalRight}
  />
</Base>

<style is:global>
  .prose-klano h2 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    color: var(--color-klano-text);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.015em;
  }
  .prose-klano p,
  .prose-klano li {
    color: var(--color-klano-text-2);
    line-height: 1.65;
    margin-bottom: 0.75rem;
    font-size: 15px;
  }
  .prose-klano a {
    color: var(--color-klano-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose-klano ul {
    list-style: disc;
    padding-left: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .prose-klano strong {
    color: var(--color-klano-text);
    font-weight: 600;
  }
</style>
